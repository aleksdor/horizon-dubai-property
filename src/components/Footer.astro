---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-navy-dark text-white overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-royal/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-16 -left-16 w-64 h-64 bg-gold/5 rounded-full blur-3xl"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 lg:pt-20 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8">
      <div class="lg:col-span-4">
        <a href="/" class="inline-block">
          <span class="font-display text-2xl font-bold text-white">Horizon</span>
          <span class="font-display text-2xl font-light text-white/60"> Dubai</span>
        </a>
        <p class="mt-4 text-sm text-white/40 leading-relaxed max-w-xs">Premium Dubai real estate for international investors. Freehold ownership, Golden Visa assistance, zero income tax.</p>
        <div class="mt-6"><a href="/contact/" class="btn-primary text-sm !px-6 !py-2.5 inline-block">Get in Touch</a></div>
      </div>
      <div class="lg:col-span-3">
        <h3 class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Areas</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/areas/dubai-marina/" class="text-white/60 hover:text-gold transition-colors">Dubai Marina</a></li>
          <li><a href="/areas/downtown/" class="text-white/60 hover:text-gold transition-colors">Downtown Dubai</a></li>
          <li><a href="/areas/palm-jumeirah/" class="text-white/60 hover:text-gold transition-colors">Palm Jumeirah</a></li>
          <li><a href="/areas/business-bay/" class="text-white/60 hover:text-gold transition-colors">Business Bay</a></li>
          <li><a href="/areas/jvc/" class="text-white/60 hover:text-gold transition-colors">JVC</a></li>
          <li><a href="/areas/dubai-hills/" class="text-white/60 hover:text-gold transition-colors">Dubai Hills</a></li>
          <li><a href="/areas/jbr/" class="text-white/60 hover:text-gold transition-colors">JBR</a></li>
        </ul>
      </div>
      <div class="lg:col-span-3">
        <h3 class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Guides</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/golden-visa/" class="text-white/60 hover:text-gold transition-colors">Golden Visa Guide</a></li>
          <li><a href="/guides/" class="text-white/60 hover:text-gold transition-colors">Buying Guide</a></li>
          <li><a href="/off-plan/" class="text-white/60 hover:text-gold transition-colors">Off-Plan Guide</a></li>
          <li><a href="/faq/" class="text-white/60 hover:text-gold transition-colors">FAQ</a></li>
          <li><a href="/properties/" class="text-white/60 hover:text-gold transition-colors">All Properties</a></li>
        </ul>
      </div>
      <div class="lg:col-span-2">
        <h3 class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Contact</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="mailto:dubai@horizonpropertyai.com" class="text-white/60 hover:text-gold transition-colors">dubai@horizon<wbr/>propertyai.com</a></li>
          <li><a href="https://wa.me/971528486680" class="text-white/60 hover:text-gold transition-colors">+971 52 848 6680</a></li>
          <li class="text-white/30">Dubai, UAE</li>
          <li class="text-white/30">UTC+4</li>
        </ul>
      </div>
    </div>
    <div class="mt-14 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/25">
      <p>&copy; {currentYear} Horizon Dubai Property. All rights reserved.</p>
      <p>RERA registered — Licensed real estate professionals</p>
    </div>
  </div>
</footer>
